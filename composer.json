{
    "name": "aybarsm/filament-sanctum-tokens",
    "version": "dev-main",
    "description": "A Filament plugin to manage Laravel Sanctum personal access tokens.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aybarsm",
        "php",
        "laravel",
        "filament"
    ],
    "homepage": "https://www.github.com/aybarsm/filament-sanctum-tokens",
    "support": {
        "email": "dev@blrm.net"
    },
    "authors": [
        {
            "name": "Murat Aybars",
            "email": "murat.aybars@blrm.net",
            "homepage": "https://www.blrm.net",
            "role": "Founder"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.4"
    },
    "autoload": {
        "psr-4": {
            "Aybarsm\\Filament\\SanctumTokens\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aybarsm\\Filament\\SanctumTokens\\FilamentSanctumTokensServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}